<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/activity_margin">

    <TextView
        android:id="@+id/status_image_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/padding_quarter"
        android:text="N"
        android:background="@drawable/bkgd_circle_white_56"
        android:gravity="center"
        android:textSize="20sp"
        android:textColor="@color/colorPrimaryDark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/message_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/messages"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingStart="15dp"
        android:paddingEnd="20dp"
        android:paddingVertical="10dp"
        android:maxWidth="250dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/transparent_overlay_message"
        app:layout_constraintStart_toEndOf="@id/status_image_view"
        app:layout_constraintTop_toTopOf="@id/status_image_view" />

    <LinearLayout
        android:id="@+id/message_metadata_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="@id/message_text_view"
        app:layout_constraintTop_toBottomOf="@id/message_text_view">

        <ImageView
            android:id="@+id/iv_encryption_status"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="3dp"
            android:contentDescription="@string/label_unencrypted_message"
            android:src="@drawable/ic_lock_open_24"
            android:visibility="gone"
            app:tint="@color/madderLake" />

        <TextView
            android:id="@+id/tv_encryption_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="@string/label_unencrypted_message"
            android:textColor="@color/madderLake"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/date_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp"
            android:text="@string/sample_date_time" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
